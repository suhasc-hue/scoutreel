# keep the image small and free of secrets / the private live DB
.git/
.venv/
__pycache__/
**/__pycache__/
*.pyc
.pytest_cache/
tests/
# secrets & private data — never ship these
.env
.env.example
credentials.json
token.json
tokens/
backups/
